generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Machine {
  id                     String        @id @default(cuid())
  name                   String        @unique
  type                   String
  size                   String        @default("normal")
  relayChannel           Int?          @unique
  defaultPriceCents      Int
  defaultDurationMinutes Int
  outOfService           Boolean       @default(false)
  awaitingRelease        Boolean       @default(false)
  isActive               Boolean       @default(true)
  lastRelayTestOk        Boolean?
  lastRelayTestAt        DateTime?
  lastRelayTestError     String?
  hardwareValidatedAt    DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  transactions           Transaction[]
  availabilityIncidents  AvailabilityIncident[]
  washerLoadAssignments  WorkOrderLoad[] @relation("WorkOrderLoadWasher")
  dryerLoadAssignments   WorkOrderLoad[] @relation("WorkOrderLoadDryer")
}

model Employee {
  id            String         @id @default(cuid())
  name          String
  pin           String
  isAdmin       Boolean        @default(false)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  shifts        Shift[]
  closedShifts  Shift[]        @relation("ShiftClosedBy")
  varianceApprovedShifts Shift[] @relation("ShiftVarianceApprovedBy")
  transactions  Transaction[]
  voidedTransactions Transaction[] @relation("TransactionVoidedBy")
  cashMovements CashMovement[]
  extensions    TransactionExtension[]
  encargoOrders EncargoOrder[] @relation("EncargoOrderCreatedBy")
  auditEvents   AuditEvent[]
  cashDrops     CashDrop[]     @relation("CashDropPerformedBy")
  approvedCashDropOverrides CashDrop[] @relation("CashDropApprovedBy")
  safeLedgerEvents SafeLedgerEvent[]
  workOrders    WorkOrder[]
}

model Customer {
  id           String        @id @default(cuid())
  firstName    String
  lastName     String
  phone        String        @unique
  email        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  encargoOrders EncargoOrder[]
  workOrders    WorkOrder[]

  @@index([lastName, firstName])
}

model Transaction {
  id                     String                 @id @default(cuid())
  ticketNumber           Int                    @unique
  machineId              String
  machine                Machine                @relation(fields: [machineId], references: [id])
  employeeId             String
  employee               Employee               @relation(fields: [employeeId], references: [id])
  customerId             String
  customer               Customer               @relation(fields: [customerId], references: [id])
  baseAmountCents        Int
  discountCents          Int                    @default(0)
  loyaltyDiscountApplied Boolean                @default(false)
  addonDetergentQty      Int                    @default(0)
  addonSoftenerQty       Int                    @default(0)
  addonBleachQty         Int                    @default(0)
  addonAmountCents       Int                    @default(0)
  serviceType            String                 @default("autoservicio")
  amountCents            Int
  paymentMethod          String
  isExtension            Boolean                @default(false)
  parentTransactionId    String?
  parentTransaction      Transaction?           @relation("TransactionParent", fields: [parentTransactionId], references: [id])
  childTransactions      Transaction[]          @relation("TransactionParent")
  encargoOrderId         String?
  encargoOrder           EncargoOrder?          @relation(fields: [encargoOrderId], references: [id])
  workOrderId            String?
  workOrder              WorkOrder?             @relation(fields: [workOrderId], references: [id])
  workOrderLoadId        String?                @unique
  workOrderLoad          WorkOrderLoad?         @relation(fields: [workOrderLoadId], references: [id])
  startedAt              DateTime
  expectedEndAt          DateTime
  status                 String                 @default("pending_relay")
  endedAt                DateTime?
  voidedAt               DateTime?
  voidedByEmployeeId     String?
  voidedByEmployee       Employee?              @relation("TransactionVoidedBy", fields: [voidedByEmployeeId], references: [id])
  relayOnAttemptedAt     DateTime?
  relayTurnedOnAt        DateTime?
  relayOffAttemptedAt    DateTime?
  relayTurnedOffAt       DateTime?
  relayFailureReason     String?
  voidReason             String?
  voidReasonCode         String?
  voidReasonNotes        String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  extensions             TransactionExtension[]

  @@index([expectedEndAt])
  @@index([status])
  @@index([customerId])
  @@index([parentTransactionId])
  @@index([encargoOrderId])
  @@index([workOrderId])
  @@index([voidedAt])
}

model WorkOrder {
  id                String      @id @default(cuid())
  orderNumber       Int         @unique
  employeeId        String
  employee          Employee    @relation(fields: [employeeId], references: [id])
  customerId        String
  customer          Customer    @relation(fields: [customerId], references: [id])
  encargoOrderId    String?
  encargoOrder      EncargoOrder? @relation(fields: [encargoOrderId], references: [id])
  serviceType       String
  paymentMethod     String
  weightKg          Float
  requiredLoads     Int
  baseAmountCents   Int
  discountCents     Int         @default(0)
  loyaltyDiscountApplied Boolean @default(false)
  addonDetergentQty Int         @default(0)
  addonSoftenerQty  Int         @default(0)
  addonBleachQty    Int         @default(0)
  addonAmountCents  Int         @default(0)
  amountCents       Int
  status            String      @default("created")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  loads             WorkOrderLoad[]
  transactions      Transaction[]
  printJobs         PrintJob[]

  @@index([createdAt])
  @@index([customerId])
  @@index([employeeId])
  @@index([encargoOrderId])
}

model WorkOrderLoad {
  id              String      @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder   @relation(fields: [workOrderId], references: [id])
  loadIndex       Int
  washerMachineId String
  washerMachine   Machine     @relation("WorkOrderLoadWasher", fields: [washerMachineId], references: [id])
  dryerMachineId  String?
  dryerMachine    Machine?    @relation("WorkOrderLoadDryer", fields: [dryerMachineId], references: [id])
  status          String      @default("assigned")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  transaction     Transaction?

  @@unique([workOrderId, loadIndex])
  @@index([washerMachineId])
  @@index([dryerMachineId])
}

model TransactionExtension {
  id              String      @id @default(cuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id])
  employeeId      String
  employee        Employee    @relation(fields: [employeeId], references: [id])
  extraMinutes    Int
  extraAmountCents Int
  reason          String?
  createdAt       DateTime    @default(now())
}

model Shift {
  id                  String         @id @default(cuid())
  employeeId          String
  employee            Employee       @relation(fields: [employeeId], references: [id])
  startTime           DateTime       @default(now())
  endTime             DateTime?
  closedByEmployeeId  String?
  closedByEmployee    Employee?      @relation("ShiftClosedBy", fields: [closedByEmployeeId], references: [id])
  status              String         @default("open")
  startingCashCents   Int
  expectedCashCents   Int?
  actualCashCents     Int?
  differenceCashCents Int?
  countedCashSubmittedAt DateTime?
  expectedCashRevealedAt DateTime?
  varianceApprovedByEmployeeId String?
  varianceApprovedByEmployee Employee? @relation("ShiftVarianceApprovedBy", fields: [varianceApprovedByEmployeeId], references: [id])
  varianceApprovalNote String?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  cashMovements       CashMovement[]
  cashDrops           CashDrop[]
  safeLedgerEvents    SafeLedgerEvent[]

  @@index([startTime])
}

model CashMovement {
  id          String           @id @default(cuid())
  shiftId     String
  shift       Shift            @relation(fields: [shiftId], references: [id])
  employeeId  String
  employee    Employee         @relation(fields: [employeeId], references: [id])
  type        String
  amountCents Int
  reason      String
  createdAt   DateTime         @default(now())

  @@index([createdAt])
}

model AppConfig {
  id                          Int      @id @default(1)
  businessName                String   @default("Punto Lavado")
  timezone                    String   @default("America/Monterrey")
  currency                    String   @default("MXN")
  serialPortPath              String   @default("COM3")
  serialBaudRate              Int      @default(9600)
  relayMockMode               Boolean  @default(false)
  relayConnected              Boolean  @default(false)
  washerNormalCycleMinutes    Int      @default(35)
  washerXlCycleMinutes        Int      @default(45)
  dryerNormalCycleMinutes     Int      @default(45)
  dryerXlCycleMinutes         Int      @default(55)
  selfServiceWashPriceCents   Int      @default(4500)
  selfServiceDryPriceCents    Int      @default(4500)
  selfServiceCycleMinutes     Int      @default(50)
  encargoPricePerKgCents      Int      @default(3300)
  encargoMinimumChargeCents   Int      @default(12000)
  xlEdredonIndividualCents    Int      @default(15000)
  xlEdredonMatrimonialCents   Int      @default(18000)
  xlEdredonKingCents          Int      @default(20000)
  xlCobijaGruesaCents         Int      @default(12000)
  xlAlmohadaParCents          Int      @default(8000)
  dryCleaningMinimumCents     Int      @default(15000)
  dryCleaningUrgentSurchargePct Int     @default(50)
  detergentAddonCents          Int      @default(500)
  softenerAddonCents           Int      @default(500)
  bleachAddonCents             Int      @default(500)
  loyaltyEveryNTransactions    Int      @default(10)
  loyaltyDiscountPct           Int      @default(50)
  downtimeThresholdMinutes     Int      @default(5)
  voidSpikePercentThreshold    Int      @default(5)
  voidSpikeAmountCents         Int      @default(50000)
  cashVarianceApprovalThresholdCents Int @default(5000)
  cashDrawerCapCents           Int      @default(200000)
  cashDrawerSoftWarningPct     Int      @default(80)
  cashDropResidualCents        Int      @default(50000)
  washerNormalCapacityKg       Float    @default(5)
  washerXlCapacityKg           Float    @default(7)
  ticketAutoPrintEnabled       Boolean  @default(true)
  ticketPrinterTransport       String   @default("node_red_http")
  ticketPrinterEndpoint        String   @default("http://127.0.0.1:1880/printer/jobs")
  ticketPrinterProfile         String   @default("epson_tm_t20iii")
  ticketPrinterTimeoutMs       Int      @default(7000)
  updatedAt                   DateTime @updatedAt
}

model EncargoOrder {
  id                String        @id @default(cuid())
  customerId        String?
  customer          Customer?     @relation(fields: [customerId], references: [id])
  customerName      String?
  customerPhone     String?
  weightKg          Float
  loads             Int           @default(1)
  notes             String?
  priceCents        Int
  paymentMode       String
  paymentStatus     String        @default("pending")
  paymentMethod     String?
  status            String        @default("order")
  createdByEmployeeId String
  createdByEmployee Employee      @relation("EncargoOrderCreatedBy", fields: [createdByEmployeeId], references: [id])
  receivedAt        DateTime      @default(now())
  readyAt           DateTime?
  deliveredAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  transactions      Transaction[]
  workOrders        WorkOrder[]

  @@index([status])
  @@index([receivedAt])
  @@index([createdByEmployeeId])
  @@index([customerId])
}

model PrintJob {
  id          String    @id @default(cuid())
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id])
  ticketType  String
  loadIndex   Int?
  status      String    @default("pending")
  payloadJson String
  attemptCount Int      @default(0)
  lastError   String?
  printedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workOrderId, status])
  @@index([ticketType, createdAt])
}

model AuditEvent {
  id              String    @id @default(cuid())
  type            String
  payloadJson     String
  actorEmployeeId String?
  actorEmployee   Employee? @relation(fields: [actorEmployeeId], references: [id])
  deviceId        String?
  createdAt       DateTime  @default(now())

  @@index([type, createdAt])
  @@index([actorEmployeeId, createdAt])
}

model VoidReason {
  code          String   @id
  label         String
  requiresNotes Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CashDrop {
  id                    String    @id @default(cuid())
  shiftId               String
  shift                 Shift     @relation(fields: [shiftId], references: [id])
  performedByEmployeeId String
  performedByEmployee   Employee  @relation("CashDropPerformedBy", fields: [performedByEmployeeId], references: [id])
  approvedByEmployeeId  String?
  approvedByEmployee    Employee? @relation("CashDropApprovedBy", fields: [approvedByEmployeeId], references: [id])
  amountCents           Int
  destination           String    @default("safe")
  reason                String
  notes                 String?
  deviceId              String?
  overrideUsed          Boolean   @default(false)
  createdAt             DateTime  @default(now())
  safeLedgerEvents      SafeLedgerEvent[]

  @@index([shiftId, createdAt])
  @@index([performedByEmployeeId, createdAt])
}

model SafeLedgerEvent {
  id                       String    @id @default(cuid())
  shiftId                  String?
  shift                    Shift?    @relation(fields: [shiftId], references: [id])
  cashDropId               String?
  cashDrop                 CashDrop? @relation(fields: [cashDropId], references: [id])
  performedByEmployeeId    String?
  performedByEmployee      Employee? @relation(fields: [performedByEmployeeId], references: [id])
  type                     String
  amountDeltaCents         Int
  expectedBalanceAfterCents Int
  countedBalanceCents      Int?
  varianceCents            Int?
  notes                    String?
  createdAt                DateTime  @default(now())

  @@index([createdAt])
  @@index([type, createdAt])
}

model AvailabilityIncident {
  id           String   @id @default(cuid())
  machineId    String
  machine      Machine  @relation(fields: [machineId], references: [id])
  relayChannel Int?
  startedAt    DateTime
  endedAt      DateTime?
  minutes      Int?
  reasonCode   String
  source       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([machineId, startedAt])
  @@index([startedAt, endedAt])
  @@index([reasonCode, startedAt])
}
